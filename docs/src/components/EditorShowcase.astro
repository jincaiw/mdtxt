---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import showcase from "../assets/screenshots/showcase-dark.png";

const chips = [
  { icon: "lucide:sigma", label: "KaTeX math + mhchem" },
  { icon: "lucide:workflow", label: "Mermaid diagrams" },
  { icon: "lucide:code", label: "Syntax highlighting" },
];
---

<section id="editor" class="relative overflow-hidden py-24 md:py-32">
  <div class="aurora" style="opacity:.12" data-parallax="4"></div>
  <div class="relative z-10 mx-auto max-w-5xl px-5">
    <div data-reveal>
      <div class="max-w-2xl">
        <p class="mono-label"><span class="tok-mark-cyan">&gt;</span> split view</p>
        <h2 class="font-serif-display mt-3 text-[clamp(2.2rem,5vw,3.5rem)]">
          Source and document, always in&nbsp;sync.
        </h2>
        <p class="mt-4 text-lg text-fg-muted">
          Write on one side, read on the other, scrolling in lockstep. Equations, chemical
          reactions, diagrams, and code all render live in the preview as you type.
        </p>
      </div>
    </div>

    <div class="mt-12" data-reveal>
      <div class="editor">
        <Image
          src={showcase}
          alt="mdtxt preview rendering an integral equation, a balanced chemical reaction, a Mermaid flowchart, and a syntax-highlighted code block"
          widths={[760, 1100, 1600, 1920]}
          sizes="(max-width: 1024px) 100vw, 1024px"
          loading="lazy"
          class="w-full"
        />
      </div>

      <div class="mt-6 flex flex-wrap gap-2.5">
        {chips.map((c) => (
          <span class="pill">
            <Icon name={c.icon} class="h-4 w-4 text-brand" /> {c.label}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
