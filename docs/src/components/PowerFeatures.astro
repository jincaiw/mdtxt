---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import AppWindow from "./AppWindow.astro";
import commandPalette from "../assets/screenshots/command-palette.png";
import fileExplorer from "../assets/screenshots/file-explorer.png";

const shots = [
  {
    img: commandPalette,
    icon: "lucide:command",
    label: "command-palette",
    title: "Command palette",
    desc: "Ctrl+P to run any command, jump to a file or heading, and toggle modes, without leaving the keyboard.",
    alt: "mdtxt command palette listing New file, Open, Save, Reveal in folder, and mode-switch commands",
  },
  {
    img: fileExplorer,
    icon: "lucide:folder-tree",
    label: "file-explorer",
    title: "File explorer & wikilinks",
    desc: "Browse the current folder, hop between notes, and follow [[wikilinks]] that resolve right in your vault.",
    alt: "mdtxt file explorer showing a folder of Markdown notes beside the rendered reader view",
  },
];
---

<section class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-5">
    <div class="max-w-2xl" data-reveal>
      <p class="mono-label"><span class="tok-mark">##</span> power-user</p>
      <h2 class="font-serif-display mt-3 text-[clamp(2.2rem,5vw,3.5rem)]">Fast hands stay fast.</h2>
      <p class="mt-4 text-lg text-fg-muted">
        The small things that add up: a keyboard-first command palette and a folder-aware file
        explorer.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {shots.map((s) => (
        <figure data-reveal>
          <AppWindow>
            <Image
              src={s.img}
              alt={s.alt}
              widths={[600, 900, 1200]}
              sizes="(max-width: 768px) 100vw, 540px"
              loading="lazy"
              class="w-full"
            />
          </AppWindow>
          <figcaption class="mt-5 flex gap-3">
            <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-line text-brand">
              <Icon name={s.icon} class="h-4 w-4" />
            </span>
            <div>
              <h3 class="font-semibold">{s.title}</h3>
              <p class="mt-1 text-[15px] leading-relaxed text-fg-muted">{s.desc}</p>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
