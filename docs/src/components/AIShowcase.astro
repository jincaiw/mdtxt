---
import { Icon } from "astro-icon/components";
import AppWindow from "./AppWindow.astro";

const points = [
  {
    icon: "lucide:message-circle",
    title: "Ask mode",
    desc: "Chat about the current document: summarize, find, or explain. Answers stream in live.",
  },
  {
    icon: "lucide:wand-sparkles",
    title: "Agent mode",
    desc: "Describe a change in plain language; edits appear as an inline diff you review and accept or reject, per change, or all at once.",
  },
  {
    icon: "lucide:text-cursor-input",
    title: "Selection assist",
    desc: "Select text and rewrite, shorten, expand, continue, or translate it in place.",
  },
  {
    icon: "lucide:key-round",
    title: "Bring your own model",
    desc: "Any OpenAI-compatible endpoint: OpenAI, Gemini, Ollama, llama.cpp. Your key lives in the OS keychain.",
  },
];
---

<section id="ai" class="relative overflow-hidden py-24 md:py-32">
  <div
    class="absolute inset-0 z-0"
    style="background:radial-gradient(60% 50% at 80% 30%, color-mix(in srgb, var(--color-cyan) 12%, transparent), transparent 70%)"
  >
  </div>

  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-14 px-5 lg:grid-cols-2">
    <div data-reveal>
      <p class="mono-label"><span class="tok-mark-cyan">&gt;</span> ai assistant</p>
      <h2 class="font-serif-display mt-3 text-[clamp(2.2rem,5vw,3.5rem)]">
        AI that <em class="text-gradient">edits</em>, not just chats.
      </h2>
      <p class="mt-4 text-lg text-fg-muted">
        Most editors bolt on a chatbot. mdtxt Agent proposes real edits to your document as a
        diff you stay in control of. Nothing is written until you say so.
      </p>

      <ul class="mt-8 space-y-5">
        {points.map((p) => (
          <li class="flex gap-4">
            <span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-line text-cyan" style="background:color-mix(in srgb, var(--color-cyan) 10%, transparent)">
              <Icon name={p.icon} class="h-[18px] w-[18px]" />
            </span>
            <div>
              <h3 class="font-semibold">{p.title}</h3>
              <p class="mt-1 text-[15px] leading-relaxed text-fg-muted">{p.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <!-- Live Agent inline-diff mock -->
    <div class="relative" data-reveal>
      <AppWindow label="notes.md" class="editor-light relative z-10">
        <div class="bg-ink-900 p-3 font-mono text-[13px] leading-relaxed">
          <!-- composer -->
          <div class="ai-composer-demo mb-3 flex items-center gap-2 rounded-lg border border-line bg-ink-850 px-3 py-2">
            <Icon name="lucide:sparkles" class="h-4 w-4 shrink-0 text-cyan" />
            <span class="truncate text-fg-muted">Tighten the opening line and fix the typo</span>
            <span class="ml-auto rounded-md bg-cyan/15 px-2 py-0.5 text-[11px] font-semibold text-cyan">Agent</span>
          </div>

          <!-- diff -->
          <div class="overflow-hidden rounded-lg border border-line">
            <div class="flex">
              <div class="select-none border-r border-line bg-ink-850 px-3 py-1 text-right text-fg-dim">1</div>
              <div class="px-3 py-1 text-fg"><span class="text-brand">#</span> Getting Started</div>
            </div>

            <div class="flex" style="background:var(--diff-del-bg);box-shadow:inset 2px 0 0 var(--diff-del-border)">
              <div class="select-none border-r border-line/40 px-3 py-1 text-right" style="color:var(--diff-del-border)">2</div>
              <div class="px-3 py-1 line-through" style="color:var(--diff-del-text)">mdtxt is a markdown editor for notes.</div>
            </div>

            <div class="flex" style="background:var(--diff-add-bg);box-shadow:inset 2px 0 0 var(--diff-add-border)">
              <div class="select-none border-r border-line/40 px-3 py-1 text-right" style="color:var(--diff-add-border)">2</div>
              <div class="px-3 py-1 text-fg">mdtxt is a fast, native Markdown editor that renders as you write.</div>
            </div>

            <div class="flex">
              <div class="select-none border-r border-line bg-ink-850 px-3 py-1 text-right text-fg-dim">3</div>
              <div class="px-3 py-1 text-fg-muted">&nbsp;</div>
            </div>

            <!-- per-chunk controls -->
            <div class="flex items-center gap-2 border-t border-line bg-ink-850 px-3 py-2">
              <span class="text-[11px] text-fg-dim">1 change proposed</span>
              <button class="ml-auto rounded-md px-2.5 py-1 text-[11px] font-semibold text-white" style="background:var(--diff-add-border)">Accept</button>
              <button class="rounded-md px-2.5 py-1 text-[11px] font-semibold text-white" style="background:var(--diff-del-border)">Reject</button>
            </div>
          </div>

          <p class="mt-3 text-[11px] text-fg-dim">Green = added · red = removed · review every edit before it touches your file.</p>
        </div>
      </AppWindow>
    </div>
  </div>
</section>
