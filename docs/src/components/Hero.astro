---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import splitDark from "../assets/screenshots/split-dark.png";
import mascotWave from "../assets/mascot/mascot-wave.png";

const repo = "https://github.com/Razee4315/MarkLite";
const releases = "https://github.com/Razee4315/MarkLite/releases/latest";
---

<header id="top" class="relative overflow-hidden pt-28 pb-16 md:pt-36 md:pb-24">
  <div class="aurora" data-parallax="6"></div>
  <div class="grid-bg"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-5">
    <!-- Intro -->
    <div class="mx-auto max-w-3xl text-center">
      <a href={releases} rel="noopener" class="pill mb-7 hover:border-white/25" data-reveal>
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-ok)]"></span>
        v1.0.0 is out · Free &amp; open source
        <Icon name="lucide:arrow-right" class="h-3.5 w-3.5 opacity-60" />
      </a>

      <h1
        class="font-serif-display mx-auto max-w-3xl text-balance text-[clamp(2.9rem,8vw,5.5rem)]"
        data-reveal
      >
        Plain text in.<br />A <em class="text-gradient text-gradient-flow">living document</em> out.
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-pretty text-lg text-fg-muted md:text-xl" data-reveal>
        MarkLite is a fast, native Markdown editor that renders math, chemistry, and diagrams live as
        you type, with an optional AI that proposes edits you accept or reject right in your text.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3" data-reveal>
        <a href="#download" class="btn btn-primary text-base">
          <Icon name="lucide:download" class="h-[18px] w-[18px]" /> Download free
        </a>
        <a href={repo} rel="noopener" class="btn btn-ghost text-base">
          <Icon name="lucide:star" class="h-[18px] w-[18px]" /> Star on GitHub
        </a>
      </div>

      <p class="mono-label mt-6 flex-wrap justify-center" data-reveal>
        <span class="tok-mark">//</span>
        no account
        <span class="text-fg-dim/60">·</span> no telemetry
        <span class="text-fg-dim/60">·</span> works offline
        <span class="text-fg-dim/60">·</span> Apache-2.0
      </p>
    </div>

    <!-- Real product screenshot -->
    <div class="relative mx-auto mt-16 max-w-5xl" data-reveal>
      <div class="shot-glow" aria-hidden="true"></div>
      <!-- Mascot peeking over the window edge: lower half sits behind the
           editor frame, so it reads as waving from behind the app. -->
      <Image
        src={mascotWave}
        alt=""
        aria-hidden="true"
        widths={[160]}
        sizes="80px"
        class="mascot-peek pointer-events-none absolute right-8 z-0 h-20 w-20 select-none md:right-14 md:h-24 md:w-24"
        loading="eager"
      />
      <div class="editor relative">
        <Image
          src={splitDark}
          alt="MarkLite in split view: syntax-highlighted Markdown source on the left, the live-rendered document with a table, task list, and headings on the right"
          widths={[760, 1100, 1600, 1920]}
          sizes="(max-width: 1024px) 100vw, 1024px"
          loading="eager"
          class="w-full"
        />
      </div>
      <p class="mt-4 text-center font-mono text-xs text-fg-dim">
        Split view: raw Markdown on the left, the live preview on the right.
      </p>
    </div>
  </div>
</header>

<style>
  /* Sits half-hidden behind the editor frame; tilted like it leaned over to wave. */
  .mascot-peek {
    top: -3.4rem;
    rotate: -6deg;
  }
  @media (min-width: 768px) {
    .mascot-peek {
      top: -4.1rem;
    }
  }

  /* Brand glow behind the product shot, gives the hero depth without chrome cliches */
  .shot-glow {
    position: absolute;
    inset: -14% 4% 18% 4%;
    z-index: 0;
    pointer-events: none;
    filter: blur(64px);
    opacity: 0.45;
    background: linear-gradient(
      100deg,
      var(--color-brand) 0%,
      transparent 42%,
      transparent 58%,
      var(--color-cyan) 100%
    );
  }
</style>
