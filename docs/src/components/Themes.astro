---
import { Image } from "astro:assets";
import readerDark from "../assets/screenshots/reader-dark.png";
import readerLight from "../assets/screenshots/reader-light.png";
import readerPaper from "../assets/screenshots/reader-paper.png";

const themes = [
  { id: "paper", label: "Paper", img: readerPaper, swatch: ["#f5f0e6", "#5c4033"] },
  { id: "dark", label: "Dark", img: readerDark, swatch: ["#0a0a0d", "#ffffff"] },
  { id: "light", label: "Light", img: readerLight, swatch: ["#ffffff", "#171717"] },
];
---

<section id="themes" class="theme-stage stage-paper py-24 md:py-32" data-theme-stage>
  <div class="relative mx-auto max-w-5xl px-5">
    <div class="max-w-2xl" data-reveal>
      <p class="mono-label" style="color:color-mix(in srgb, var(--stage-fg) 55%, transparent)">
        <span style="color:var(--color-brand)">##</span> themes
      </p>
      <h2 class="font-serif-display mt-3 text-[clamp(2.2rem,5vw,3.5rem)]" style="color:var(--stage-fg)">
        Not just another dark tool.
      </h2>
      <p class="mt-4 text-lg" style="color:var(--stage-muted)">
        Dark, Light, a warm Paper mode, and a Dracula theme for night owls, plus focus and typewriter
        modes. Tap one and watch this whole section change with it.
      </p>
    </div>

    <div class="mt-9 flex flex-wrap gap-2" data-reveal data-theme-tabs>
      {themes.map((t, i) => (
        <button
          type="button"
          data-theme-tab={t.id}
          aria-pressed={i === 0 ? "true" : "false"}
          class="theme-tab inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm transition-colors"
        >
          <span class="flex h-4 w-4 overflow-hidden rounded-full ring-1 ring-black/15">
            <span class="h-full w-1/2" style={`background:${t.swatch[0]}`}></span>
            <span class="h-full w-1/2" style={`background:${t.swatch[1]}`}></span>
          </span>
          {t.label}
        </button>
      ))}
    </div>

    <div class="mt-7" data-reveal>
      <div class="editor">
        <div class="relative aspect-[1920/1030] w-full bg-ink-900">
          {themes.map((t, i) => (
            <Image
              src={t.img}
              alt={`mdtxt ${t.label} theme rendering a Markdown document`}
              widths={[760, 1100, 1600]}
              sizes="(max-width: 1024px) 100vw, 1024px"
              loading="lazy"
              data-theme-panel={t.id}
              class={`absolute inset-0 h-full w-full object-cover object-top transition-opacity duration-500 ${
                i === 0 ? "opacity-100" : "opacity-0"
              }`}
            />
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .theme-stage {
    --stage-bg: #f5f0e6;
    --stage-fg: #2b2420;
    --stage-muted: #6f6149;
    --stage-line: #e3d8c2;
    background-color: var(--stage-bg);
    transition: background-color 0.55s var(--ease-out-expo), color 0.55s var(--ease-out-expo);
  }
  .stage-paper  { --stage-bg:#f5f0e6; --stage-fg:#2b2420; --stage-muted:#6f6149; --stage-line:#e3d8c2; }
  .stage-dark   { --stage-bg:#0a0a0d; --stage-fg:#f7f7fa; --stage-muted:#a7a7b4; --stage-line:#20202a; }
  .stage-light  { --stage-bg:#ffffff; --stage-fg:#171717; --stage-muted:#525252; --stage-line:#e5e5e5; }

  .theme-tab {
    color: color-mix(in srgb, var(--stage-fg) 70%, transparent);
    border: 1px solid color-mix(in srgb, var(--stage-fg) 18%, transparent);
    background: color-mix(in srgb, var(--stage-fg) 4%, transparent);
  }
  .theme-tab:hover {
    color: var(--stage-fg);
    border-color: color-mix(in srgb, var(--stage-fg) 32%, transparent);
  }
  .theme-tab[aria-pressed="true"] {
    color: var(--stage-fg);
    border-color: var(--color-brand);
    background: color-mix(in srgb, var(--color-brand) 14%, transparent);
  }
</style>

<script>
  const stage = document.querySelector<HTMLElement>("[data-theme-stage]");
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-theme-tab]"));
  const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-theme-panel]"));

  function show(id: string) {
    if (stage) {
      stage.classList.remove("stage-paper", "stage-dark", "stage-light");
      stage.classList.add(`stage-${id}`);
    }
    tabs.forEach((t) => t.setAttribute("aria-pressed", t.dataset.themeTab === id ? "true" : "false"));
    panels.forEach((p) => {
      const on = p.dataset.themePanel === id;
      p.classList.toggle("opacity-100", on);
      p.classList.toggle("opacity-0", !on);
    });
  }

  tabs.forEach((t) => t.addEventListener("click", () => show(t.dataset.themeTab || "paper")));
</script>
