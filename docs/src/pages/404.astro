---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
---

<Base title="404 · mdtxt" description="The requested mdtxt documentation page was not found.">
  <main class="flex min-h-screen items-center justify-center px-6 text-center text-fg">
    <div><p class="mono-label justify-center">404</p><h1 class="font-serif-display mt-4 text-5xl">Page not found.</h1><p class="mt-4 text-fg-muted">此文档页面不存在或已移动。</p><a href={base} class="btn btn-primary mt-8">返回 mdtxt 文档首页</a></div>
  </main>
</Base>
