---
import "@fontsource-variable/inter";
import "@fontsource/instrument-serif/400.css";
import "@fontsource/jetbrains-mono/400.css";
import "../styles/global.css";

interface Props { title?: string; description?: string; }
const { title = "mdtxt：本地优先的 Markdown 编辑器", description = "mdtxt 是一个默认简体中文、完整支持英语的跨平台 Markdown 编辑器。" } = Astro.props;
const base = import.meta.env.BASE_URL;
const canonical = new URL(base, Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang="zh-CN"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>{title}</title><meta name="description" content={description} /><meta name="keywords" content="mdtxt, markdown editor, markdown 编辑器, 本地优先, Tauri" /><meta name="theme-color" content="#f7f1e5" /><link rel="canonical" href={canonical} /><link rel="icon" type="image/svg+xml" href={`${base}icon.svg`} /><meta property="og:type" content="website" /><meta property="og:site_name" content="mdtxt" /><meta property="og:title" content={title} /><meta property="og:description" content={description} /></head><body class="grain"><slot /></body></html>
